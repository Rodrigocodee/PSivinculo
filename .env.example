# Frontend public variables (safe to expose in Vite bundles)
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=SUPABASE_ANON_PUBLIC_KEY
VITE_API_BASE_URL=http://127.0.0.1:3001

# Backend secrets (never expose in frontend)
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_SECRET
SUPABASE_ANON_KEY=SUPABASE_ANON_PUBLIC_KEY

ASAAS_API_KEY=ASAAS_API_SECRET
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# ASAAS_API_URL can be used as an alias for ASAAS_BASE_URL.
# ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=ASAAS_WEBHOOK_SHARED_SECRET

RESEND_API_KEY=RESEND_API_SECRET
EMAIL_FROM=Psivinculo <no-reply@example.com>

CRON_SECRET=INTERNAL_CRON_SECRET
APP_BASE_URL=http://localhost:8080
FRONTEND_PUBLIC_URL=http://localhost:8080
BACKEND_PUBLIC_URL=http://127.0.0.1:3001

HOST=0.0.0.0
PORT=3001
